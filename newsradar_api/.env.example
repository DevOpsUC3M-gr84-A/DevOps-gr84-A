# ============================================================
# NewsRadar — Plantilla de variables de entorno del backend
# ============================================================
# Este archivo se versiona en el repo. NUNCA comitear el .env real.
# evaluate.sh copia este fichero a `.env` automáticamente si no existe,
# garantizando que `make evaluate` arranque desde una carpeta limpia
# (RNF05 — automatización de la configuración / RNF10 — pipeline reproducible).

# --- Base de Datos (Docker interno) ---
# Host = `postgres` porque ese es el nombre del servicio en docker-compose.yml.
# Para la vía Desarrollador (uvicorn local) sustituye `postgres` por `localhost`.
DATABASE_URL=postgresql://newsradar_user:newsradar_password@postgres:5432/newsradar_db
POSTGRES_USER=newsradar_user
POSTGRES_PASSWORD=newsradar_password
POSTGRES_DB=newsradar_db

# --- Agente de monitorización de alertas (RF01) ---
ALERT_MONITOR_CRON="*/15 * * * *"

# --- Seguridad y superusuario ---
FIRST_SUPERUSER_EMAIL=admin@newsradar.com
FIRST_SUPERUSER_PASSWORD=admin123456
NEWSRADAR_ADMIN_PASSWORD=admin123456
NEWSRADAR_LECTOR_PASSWORD=lector123456

# --- URLs y CORS ---
FRONTEND_URL=http://localhost:5173
NEWSRADAR_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:8000

# --- SMTP (envío de emails de verificación / recuperación) ---
# Valores por defecto NO funcionales: el sistema arranca, pero no enviará correos
# reales hasta que el evaluador (o el equipo) ponga sus credenciales SMTP.
# Para Gmail: SMTP_PASSWORD debe ser un App Password de 16 caracteres.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=changeme@example.com
SMTP_PASSWORD=changeme-app-password
SMTP_FROM=changeme@example.com
