# ============================================================
# NewsRadar UI — Plantilla de variables de entorno del frontend
# ============================================================
# Este archivo se versiona en el repo. evaluate.sh lo copia a `.env`
# automáticamente si no existe (RNF05 / RNF10).
#
# El navegador del evaluador resuelve la API contra el puerto publicado
# en el host (8000), NO contra el nombre de servicio interno `api-backend`.

VITE_API_BASE_URL=http://localhost:8000
